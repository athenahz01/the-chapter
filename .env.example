# ─────────────────────────────────────────────────────────────────────
# The Chapter — environment variables
#
# Set these in Vercel (Project → Settings → Environment Variables).
# For local development, copy this file to `.env.local` and fill it in.
# ─────────────────────────────────────────────────────────────────────

# Resend (email delivery) — required
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address. Until you verify a domain in Resend, you can only use
# "onboarding@resend.dev" AND it will only deliver to the email address
# registered on your Resend account. Verify a domain for real delivery.
FROM_EMAIL=The Chapter <chapters@yourdomain.com>

# Anthropic (Claude API) — required for AI preludes and chapter-text fallback
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional — override the default models.
# Chapter-text fallback needs quality + length, so Sonnet is the default.
# Preludes are short, so Haiku (5x cheaper, faster) is the default.
# ANTHROPIC_MODEL_TEXT=claude-sonnet-4-5
# ANTHROPIC_MODEL_PRELUDE=claude-haiku-4-5

# Optional — lock the API down to a specific origin (recommended for
# production). Leave unset for open CORS during development.
# ALLOWED_ORIGIN=https://thechapter.co

# ─────────────────────────────────────────────────────────────────────
# Server-side subscriptions + scheduled delivery (optional but recommended)
# ─────────────────────────────────────────────────────────────────────

# Any Postgres connection string: Neon (neon.tech, free tier), Supabase,
# Vercel Postgres, Railway… The schema auto-creates on first use — just paste
# the URL, no migration step. Without this, the app runs in local-only mode
# (scheduled emails only send while a tab is open).
# DATABASE_URL=postgres://user:pass@host/db

# Protects /api/cron from being triggered by strangers. Vercel automatically
# sends it as a Bearer token with each cron invocation when set.
# CRON_SECRET=some-long-random-string

# Canonical site origin used in email links (falls back to the request host).
# PUBLIC_ORIGIN=https://thechapter.co

# ─────────────────────────────────────────────────────────────────────
# Stripe payments (optional — without these, paid plans activate free "beta")
# ─────────────────────────────────────────────────────────────────────
# Create three Prices in the Stripe dashboard and paste their ids:
#   $5/month recurring, $40/year recurring, $3 one-time.
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_PRICE_MONTHLY=price_xxx
# STRIPE_PRICE_ANNUAL=price_xxx
# STRIPE_PRICE_ALACARTE=price_xxx

# ─────────────────────────────────────────────────────────────────────
# The Chapter — environment variables
#
# Set these in Vercel (Project → Settings → Environment Variables).
# For local development, copy this file to `.env.local` and fill it in.
# ─────────────────────────────────────────────────────────────────────

# Resend (email delivery) — required
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address. Until you verify a domain in Resend, you can only use
# "onboarding@resend.dev" AND it will only deliver to the email address
# registered on your Resend account. Verify a domain for real delivery.
FROM_EMAIL=The Chapter <chapters@yourdomain.com>

# Anthropic (Claude API) — required for AI preludes and chapter-text fallback
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional — override the default models.
# Chapter-text fallback needs quality + length, so Sonnet is the default.
# Preludes are short, so Haiku (5x cheaper, faster) is the default.
# ANTHROPIC_MODEL_TEXT=claude-sonnet-4-5
# ANTHROPIC_MODEL_PRELUDE=claude-haiku-4-5

# Optional — lock the API down to a specific origin (recommended for
# production). Leave unset for open CORS during development.
# ALLOWED_ORIGIN=https://thechapter.co
